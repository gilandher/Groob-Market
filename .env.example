# ─── FRONTEND (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1


# ─── BACKEND (Django) ─────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=tu_secreto_super_seguro_aqui_para_desarrollo
DJANGO_DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,backend
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Información de contacto
WHATSAPP_NUMBER=573011963515
GROOB_WHATSAPP=573011963515

# Servicio de Correos (vía Resend SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=tu_password_de_resend_aqui # <- PONER EL PASS REAL AQUÍ
DEFAULT_FROM_EMAIL=Groob Market <onboarding@resend.dev>

# Configuración del Sitio
SITE_URL=http://localhost:3000

